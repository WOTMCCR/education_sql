# Copy this file to `.env` and fill in local or deployment-specific values.
# Do not commit real credentials.

HEALTH_REQUIRED_DEPENDENCIES=mongodb
MONGO_URI=mongodb://<host>:<port>
MONGO_DB=<chat_history_database>

ANALYTICS_MYSQL_HOST=<host>
ANALYTICS_MYSQL_PORT=3306
ANALYTICS_MYSQL_USER=<user>
ANALYTICS_MYSQL_PASSWORD=<password>
ANALYTICS_MYSQL_DATABASE=<analytics_database>
ANALYTICS_MYSQL_TIMEOUT_SECONDS=2

ANALYTICS_QDRANT_URL=http://<host>:6333
ANALYTICS_QDRANT_COLUMN_COLLECTION=edu_column_info
ANALYTICS_QDRANT_METRIC_COLLECTION=edu_metric_info
ANALYTICS_QDRANT_TIMEOUT_SECONDS=2

ANALYTICS_ES_URL=http://<host>:9200
ANALYTICS_ES_DIMENSION_VALUES_INDEX=edu_dimension_values
ANALYTICS_ES_TIMEOUT_SECONDS=2

ANALYTICS_EMBEDDING_URL=http://<host>:8081
ANALYTICS_EMBEDDING_TIMEOUT_SECONDS=5
ANALYTICS_EMBEDDING_MODE=tei

OPENAI_API_KEY=<api_key>
OPENAI_BASE_URL=<optional_compatible_base_url>
LLM_MODEL=<model_name>
